do
  bpm 70
  d1
    $ bite "6" "{0 3 2}%{2 4}"
    $ every 7 rev
    $ stack [
      sh "5%3" ((|* g 0.85).(every 5 ((chop "<2 4 3>").(ply "{19 37 45 32}%6")))) $
        n "0 1 3"
      , ply (iter 3 "1*3 3") $ n "4*5" # legato 0.1 |* sp 4
    ]
    # s "dald"
    # tanh 10
    # dis 2
    # smarm 18
    -- (trigger $ slow 5 $ range 20 100 $ envL)


do
  bpm 70
  d1
    $ off "t" ((|* g 0.9).(|+ dis 15).(# coarse 1))
    $ every 7 rev
    $ stack [
      sh "5%3" ((|* g 0.95).(every 5 ((chop "<5 3 8 14>").(ply "23 43 52"))))
        $ n "0 1 [2|3]",
      ply (iter 3 "1 6 1 1 3")
        $ n "4*5" # legato 0.1 |* sp 4 |* g 0.9
    ]
    # s "dald" # tanh 10 # dis 2 # smarm 90



do
  bpm 70
  d1
    $ ply 3
    $ echoWith 7 "[t|x]" ((|* g 0.97).(|+ dis 25).(# coarse 1))
    $ every 7 rev
    $ stack [
      sh "5%3" ((|* g 0.95).(every 5 ((chop "<5 4 14>").(ply "23 43 53").(# legato 0.6))))
        $ n "0 1 2",
      ply (iter 3 "1 3 1 12 1 6")
        $ n "4*5" # legato 0.1 |* sp 4
        |* g 1 # ac (slow 6 $ ((sine * 5) - 1))
    ]
    # s "dald" #tanh 10 # dis 2 # smarm 95






do
  bpm 70
  d1
    $ echoWith 4 "t" ((|* g 0.9)
      .(|+ dis 20).(|* sp 0.6)
      .(# coarse 2).(# cut 1))
    $ every 7 rev
    $ stack [
      sh "5%3" ((|* g 0.9)
          .(every 3 ((chop "<4 7 5>")
            .(ply "23 15 36"))))
        $ n "0 1 [2|3]",
      ply (iter 3 "12 1 1 3 1 1 6")
        $ n "4*5" # legato 0.1
        |* g 0.9 |* sp 4
        # ac (slow 4 $ ((sine*2)-1))
    ]
    # s "dald"
    # tanh 100 |+ dis 3
    # smarm 70
    |* g 1.7





do
  bpm 70
  d1
    $ echoWith 8 "1%36" ((|* g 0.98)
      .(|* sp (iter 12 "0.9 1.9"))
      .(# crush "2 5 1 10"))
    $ stack [
      sh "5%3" ((|* g 0.9)
