do
  bpm 70
  d1
    $ echoWith 5 "[x|1%46|1%48]" ((|* sp 0.9)
      .(|* g 0.9).(# crush 3).(|+ dis 5))
    $ stack [
      sh "5%3" ((|* g 0.9).(every 5 (
          (chop "4 7 2 9").(ply "18 32 24 14")
          .(# cut 1))))
        $ n "0 [1 1?] [2|3]",
      ply (iter 3 "6 1 12 1 3 1 1") $ n "4*5"
        # legato 0.1
        |* sp 4 |* g 0.9
    ]
    # s "dald"
    # tanh 100090000000000 
