      sh "5%3" ((|* g 0.85).(every 5 ((ply "45 32 16").(chop "<2 3 4>")))) $
        n "{0 1 2}%{3}"
        , ply (iter 3 "1! 3") $ n "4*5" # legato 0.2 # g 0.9
    ]
    # s "dald"
    # tanh 40
    # dis 2
